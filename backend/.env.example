# --- База данных ---
# Основная БД для запуска приложения
DATABASE_URL=postgresql+psycopg://neftegaz:neftegaz@localhost:5432/neftegaz
# Отдельная БД для прогона pytest (порт 5433)
TEST_DATABASE_URL=postgresql+psycopg://neftegaz:neftegaz@localhost:5433/neftegaz_test

# --- Безопасность ---
# В проде заменить на длинную случайную строку (openssl rand -hex 32)
SECRET_KEY=change_me_to_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Список origin'ов фронтенда через запятую
CORS_ORIGINS=http://localhost:5173
